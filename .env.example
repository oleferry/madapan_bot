TELEGRAM_BOT_TOKEN=
TELEGRAM_INTERNAL_CHAT_ID=
# Chat de destino de los albaranes diarios en PDF. Si se deja vacío, usa
# TELEGRAM_INTERNAL_CHAT_ID.
WAYBILLS_CHAT_ID=
HOLDED_API_KEY=
HOLDED_API_BASE_URL=https://api.holded.com/api/invoicing/v1
HOLDED_CONTACTS_URL=https://api.holded.com/api/contacts/v1
PRIVACY_POLICY_URL=https://www.madapan.es/privacidad
TIMEZONE=Europe/Madrid
AUTO_CHANGE_LIMIT_HOUR=20
DAILY_SUMMARY_HOUR=0
NODE_ENV=development
DRY_RUN=true

# Almacenamiento persistente.
# En Railway, crea un VOLUMEN y monta su ruta aquí (p.ej. /data) para que los
# pedidos de pizza, el stock, la caché de clientes y los logs NO se pierdan en
# cada despliegue. Si se define DATA_DIR, todos esos ficheros van ahí dentro.
# En local, déjalo vacío: se usan las rutas data/ y logs/ de siempre.
# (Railway también expone RAILWAY_VOLUME_MOUNT_PATH automáticamente y sirve igual.)
DATA_DIR=
# Overrides opcionales por-fichero (normalmente NO hacen falta si usas DATA_DIR):
# CLIENTS_CACHE_PATH=
# LOG_PATH=
# PIZZA_ORDERS_LOG_PATH=
# PIZZA_STOCK_PATH=
